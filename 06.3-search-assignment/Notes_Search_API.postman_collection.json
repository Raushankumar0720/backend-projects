  "item": [
    {
      "name": "1. CRUD Operations",
      "item": [
        {
          "name": "Create Note (POST /api/notes)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Work standup meeting\",\n  \"content\": \"Discuss deployment targets and hooks\",\n  \"category\": \"work\",\n  \"isPinned\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/notes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes"
              ]
            },
            "description": "Creates a single note. Title and Content are required."
          },
          "response": []
        },
        {
          "name": "Create Bulk Notes (POST /api/notes/bulk)",
