    {
      "name": "2. Search Queries",
      "item": [
        {
          "name": "Search Title Only (GET /api/notes/search)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notes/search?q=Study",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Study",
                  "description": "Required query text keyword"
                }
              ]
            },
            "description": "Searches case-insensitively in the note title only."
          },
          "response": []
        },
        {
          "name": "Search Content Only (GET /api/notes/search/content)",
          "request": {
            "method": "GET",
