    {
      "name": "3. Two Concepts Combined",
      "item": [
        {
          "name": "Filter and Sort (GET /api/notes/filter-sort)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notes/filter-sort?category=study&sortBy=title&order=asc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes",
                "filter-sort"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "study",
                  "description": "Optional category filter"
                },
                {
                  "key": "isPinned",
                  "value": "false",
                  "disabled": true,
                  "description": "Optional pinning status filter"
                },
                {
                  "key": "sortBy",
                  "value": "title",
                  "description": "Sort field (title, createdAt, updatedAt, category)"
                },
                {
                  "key": "order",
                  "value": "asc",
                  "description": "Sort order (asc, desc)"
                }
              ]
            },
            "description": "Applies query-parameter filters and sorts results."
          },
          "response": []
        },
        {
          "name": "Filter and Paginate (GET /api/notes/filter-paginate)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notes/filter-paginate?isPinned=true&page=1&limit=2",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes",
                "filter-paginate"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "work",
                  "disabled": true,
                  "description": "Optional category filter"
                },
                {
                  "key": "isPinned",
                  "value": "true",
                  "description": "Optional pinning status filter"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (defaults to 1)"
                },
                {
                  "key": "limit",
                  "value": "2",
                  "description": "Results per page (defaults to 10)"
                }
              ]
            },
            "description": "Filters notes by query attributes and returns paginated results with page metadata."
          },
          "response": []
        },
        {
          "name": "Sort and Paginate (GET /api/notes/sort-paginate)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notes/sort-paginate?sortBy=title&order=asc&page=1&limit=4",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes",
                "sort-paginate"
              ],
              "query": [
                {
                  "key": "sortBy",
                  "value": "title",
                  "description": "Sort field"
                },
                {
                  "key": "order",
                  "value": "asc",
                  "description": "Sort order (asc, desc)"
                },
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "4",
                  "description": "Results limit"
                }
              ]
            },
            "description": "Sorts the whole list of notes and paginates the output."
          },
          "response": []
        },
        {
          "name": "Search and Filter (GET /api/notes/search-filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/notes/search-filter?q=work&isPinned=true",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "notes",
                "search-filter"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "work",
                  "description": "Required search keyword"
                },
                {
                  "key": "category",
                  "value": "work",
                  "disabled": true,
                  "description": "Optional category filter"
                },
                {
                  "key": "isPinned",
                  "value": "true",
                  "description": "Optional pinning status filter"
                }
              ]
            },
            "description": "Searches notes matching a query word, and filters results concurrently."
          },
          "response": []
        }
      ]
