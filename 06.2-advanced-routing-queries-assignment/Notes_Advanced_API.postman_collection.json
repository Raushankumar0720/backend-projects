            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Completely new title\",\n  \"content\": \"Completely new content\",\n  \"category\": \"personal\",\n  \"isPinned\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notes/:id",
              "host": ["{{base_url}}"],
