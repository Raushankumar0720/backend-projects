          "name": "17. Paginate by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/paginate/category/:category?page=1&limit=3",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "paginate", "category", ":category"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "3"
                }
              ],
              "variable": [
                {
                  "key": "category",
                  "value": "work"
                }
              ]
            }
          }
        }
