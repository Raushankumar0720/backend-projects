    {
      "name": "3. Query Parameters",
      "item": [
        {
          "name": "12. General Filter",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/filter?category=work&isPinned=true",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "filter"],
              "query": [
                {
                  "key": "category",
                  "value": "work"
                },
                {
                  "key": "isPinned",
                  "value": "true"
                }
              ]
            }
          }
        },
        {
          "name": "13. Filter Pinned Notes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/filter/pinned?category=work",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "filter", "pinned"],
              "query": [
                {
                  "key": "category",
                  "value": "work"
                }
              ]
            }
          }
        },
        {
          "name": "14. Filter by Category (Query)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/filter/category?name=work",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "filter", "category"],
              "query": [
                {
                  "key": "name",
                  "value": "work"
                }
              ]
            }
          }
        },
        {
          "name": "15. Filter by Date Range",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/filter/date-range?from=2024-01-01&to=2024-12-31",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "filter", "date-range"],
              "query": [
                {
                  "key": "from",
                  "value": "2024-01-01"
                },
                {
                  "key": "to",
                  "value": "2024-12-31"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Pagination",
      "item": [
