    },
    {
      "name": "5. Sorting",
      "item": [
        {
          "name": "18. Sort All Notes",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notes/sort?sortBy=title&order=asc",
              "host": ["{{base_url}}"],
              "path": ["api", "notes", "sort"],
              "query": [
                {
                  "key": "sortBy",
                  "value": "title"
                },
                {
                  "key": "order",
                  "value": "asc"
